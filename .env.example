# HexaCore environment (copy to .env). Phase-0 values are placeholders.

# Model router (Brain/01 §3.3, Brain/02 §1)
HEXACORE_MODEL_PROFILE=local            # deterministic (FIFO, offline) | local/ollama
OLLAMA_HOST=http://localhost:11434
HEXACORE_OLLAMA_MODEL=llama3.2          # `ollama pull <model>` first; else router falls back to FIFO

# Datastores (used from Phase 0 DB work onward)
POSTGRES_DSN=postgresql+asyncpg://hexacore:hexacore@localhost:5432/hexacore
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=hexacore
MINIO_SECRET_KEY=change-me

# Auth (the app reads HEXACORE_JWT_SECRET; keep this name or tokens use the insecure default)
HEXACORE_JWT_SECRET=change-me-in-production

# Safety
AUDIT_LOG_PATH=var/audit.jsonl

# Persistence: unset = in-memory (engagements lost on restart).
# Set to persist engagements durably. SQLite (file) or Postgres.
# HEXACORE_DB_URL=sqlite:///hexacore.db
# HEXACORE_DB_URL=postgresql+psycopg://hexacore:hexacore@localhost:5432/hexacore

# Tool-runner backend (Brain/07). Switch where tools execute WITHOUT changing any other code.
#   dryrun = build commands, run nothing (default / CI)
#   local  = run on this host (dev boxes with tools installed)
#   docker = ephemeral Kali container per run (recommended)
#   vm     = run on a Kali VirtualBox/appliance over SSH (point at its IP)
HEXACORE_RUNNER_BACKEND=local
HEXACORE_KALI_IMAGE=hexacore/kali-tools:latest
HEXACORE_TOOLNET=hexacore_toolnet

# VM backend (only used when HEXACORE_RUNNER_BACKEND=vm)
HEXACORE_VM_HOST=192.168.56.20
HEXACORE_VM_USER=kali
HEXACORE_VM_PORT=22
HEXACORE_VM_KEY=~/.ssh/hexacore_kali
# HEXACORE_VM_PASSWORD=      # needs sshpass; an SSH key is simpler and safer
